---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - ./clusterissuer.yaml
  - ./secret.sops.yaml
helmCharts:
  - name: cert-manager
    repo: oci://quay.io/jetstack/charts
    version: v1.20.1
    releaseName: cert-manager
    namespace: cert-manager
    includeCRDs: true
    valuesFile: ./values.yaml
