---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - ./certificate.yaml
  - ./envoy.yaml
  - ./podmonitor.yaml
helmCharts:
  - name: gateway-helm
    repo: oci://mirror.gcr.io/envoyproxy
    version: v1.7.0
    releaseName: envoy-gateway
    namespace: network
    includeCRDs: true
    valuesFile: ./values.yaml
